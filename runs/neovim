#!/usr/bin/env bash
set -e

install_dir="$HOME/.local/share/nvim"
archive_name="nvim-linux-x86_64.tar.gz"
download_url="https://github.com/neovim/neovim/releases/latest/download/${archive_name}"

echo "removing previously installed version..."
rm -rf "$install_dir"
mkdir -p "$install_dir"

echo "downloading neovim..."
curl -LO "$download_url"

echo "extracting..."
tar -xzf "$archive_name" -C "$install_dir" --strip-components=1

echo "cleaning up..."
rm "$archive_name"

echo "installed neovim successfully"
